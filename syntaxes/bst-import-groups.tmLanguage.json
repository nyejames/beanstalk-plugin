{
  "version": "0.2.2",
  "name": "Beanstalk Import Group Highlighting",
  "scopeName": "source.bst.import-groups",
  "injectionSelector": "L:source.bst - meta.template.body.bst - string - comment",
  "patterns": [
    {
      "include": "#path-literals"
    }
  ],
  "repository": {
    "path-literals": {
      "patterns": [
        {
          "name": "meta.path.import.bst",
          "begin": "(@)(\\()",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.path.begin.bst keyword.control.import.bst"
            },
            "2": {
              "name": "punctuation.section.group.begin.bst"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.path.end.bst punctuation.section.group.end.bst"
            }
          },
          "patterns": [
            {
              "include": "#path-group"
            },
            {
              "name": "punctuation.separator.path.bst",
              "match": "[\\\\/]"
            },
            {
              "name": "constant.other.path.relative.bst",
              "match": "\\.{1,2}(?=[\\\\/\\)])"
            },
            {
              "name": "entity.name.path.segment.bst entity.name.module.bst",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "text.whitespace.bst",
              "match": "\\s+"
            },
            {
              "name": "invalid.illegal.path.character.bst",
              "match": "[^\\sA-Za-z0-9_{}\\\\/,\\.]"
            }
          ]
        },
        {
          "name": "meta.path.import.bst",
          "begin": "(@)(?!\\()(?=[A-Za-z_./\\\\])",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.path.begin.bst keyword.control.import.bst"
            }
          },
          "end": "(?=$|\\s+(?!\\{)|[,;\\]\\)\\}])",
          "patterns": [
            {
              "include": "#path-group"
            },
            {
              "name": "punctuation.separator.path.bst",
              "match": "[\\\\/]"
            },
            {
              "name": "constant.other.path.relative.bst",
              "match": "\\.{1,2}(?=[\\\\/\\s\\]\\)\\},;]|$)"
            },
            {
              "name": "entity.name.path.segment.bst entity.name.module.bst",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "text.whitespace.bst",
              "match": "\\s+"
            },
            {
              "name": "invalid.illegal.path.character.bst",
              "match": "[^\\sA-Za-z0-9_{}\\\\/,\\.]"
            }
          ]
        }
      ]
    },
    "path-group": {
      "patterns": [
        {
          "name": "meta.path.import.group.bst",
          "begin": "\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.group.begin.bst"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.group.end.bst"
            }
          },
          "patterns": [
            {
              "include": "#path-group"
            },
            {
              "name": "keyword.other.alias.bst keyword.other.bst",
              "match": "\\bas\\b"
            },
            {
              "name": "punctuation.separator.path.bst",
              "match": "[\\\\/]"
            },
            {
              "name": "constant.other.path.relative.bst",
              "match": "\\.{1,2}(?=[\\\\/\\s\\]\\)\\},;]|$)"
            },
            {
              "name": "entity.name.import.symbol.bst variable.other.object.property.bst",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.comma.bst",
              "match": ","
            },
            {
              "name": "text.whitespace.bst",
              "match": "\\s+"
            },
            {
              "name": "invalid.illegal.path.group.character.bst",
              "match": "[^\\sA-Za-z0-9_{}\\\\/,\\.]"
            }
          ]
        }
      ]
    }
  }
}
