{
    "version": "0.1.84",
    "name": "Beanstalk",
    "scopeName": "source.bst",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#scenes"
        },
        {
            "include": "#types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#assignment"
        },
        {
            "include": "#punctuation"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#control-statement"
        },
        {
            "include": "#collections"
        },
        {
            "include": "#lib-functions"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.bst",
                    "match": "--(?!-)[^\n]*"
                }
            ]
        },
        "scenes": {
            "patterns": [
                {
                    "name": "entity.name.tag.scene.bst",
                    "begin": "\\[",
                    "end": "\\]",
                    "patterns": [
                        {
                            "include": "#code-blocks"
                        },
                        {
                            "include": "#tuples"
                        },
                        {
                            "name": "keyword.declaration.tag.bst",
                            "end": "(?=:)",
                            "patterns": [
                                {
                                    "name": "meta.paragraph.markdown",
                                    "begin": "(?<=:)",
                                    "end": "(?=\\])",
                                    "patterns": [
                                        {
                                            "include": "#scenes",
                                            "begin": "\\["
                                        },
                                        {
                                            "name": "punctuation.definition.heading.markdown",
                                            "match": "^\\s*#+\\s.*"
                                        },
                                        {
                                            "include": "#numbers"
                                        },
                                        {
                                            "name": "punctuation.definition.bold.markdown",
                                            "match": "\\*\\*[^\\*]+\\*\\*"
                                        },
                                        {
                                            "name": "punctuation.definition.italic.markdown",
                                            "match": "\\*[^\\*]+\\*"
                                        }
                                    ]
                                },
                                {
                                    "include": "#types"
                                },
                                {
                                    "include": "#strings"
                                },
                                {
                                    "include": "#assignment"
                                },
                                {
                                    "include": "#operators"
                                },
                                {
                                    "include": "#numbers"
                                },
                                {
                                    "include": "#control-statement"
                                },
                                {
                                    "include": "#punctuation"
                                },
                                {
                                    "include": "#collections"
                                },
                                {
                                    "include": "#variables"
                                },
                                {
                                    "include": "#scene-tags"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.bst",
                    "match": "\\b(?:Int|Float|Decimal|Bool|String|Template|Choice|Type|Error|true|false|True|False|Function|async|\\$|\\?|\\!)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.bst",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.bst",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "assignment": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment",
                    "match": "=|@"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.control.bst",
                    "match": "\\b(?:and|or|not|is|in|to)\\b"
                },
                {
                    "name": "keyword.operator.symbol.bst",
                    "match": "(?:<=|>=|=>|>>|<<|->|<|>|\\+|\\-|\\*|\\/|\\%|\\^)"
                }
            ]
        },
        "collections": {
            "patterns": [
                {
                    "comment": "ALL CAPS constants",
                    "name": "constant.other.caps.bst",
                    "match": "\\b[A-Z]{2}[A-Z0-9_]*\\b"
                },
                {
                    "comment": "structs are any variable name in PascalCase",
                    "name": "entity.name.type.struct.bst",
                    "match": "\\b(?=[A-Z][A-Za-z0-9_]*[a-z])[A-Z][A-Za-z0-9_]*\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.bst",
                    "match": "\\b(?:\\d+(?:\\.\\d*)?|\\.\\d+)(?:[eE][+-]?\\d+)?\\b"
                }
            ]
        },
        "control-statement": {
            "patterns": [
                {
                    "name": "keyword.control.bst",
                    "match": "\\b(?:if|else|loop|return|continue|defer|as|copy)\\b"
                }
            ]
        },
        "punctuation": {
			"patterns": [
				{
					"comment": "comma",
					"name": "keyword.punctuation.comma.bst",
					"match": ","
				},
				{
					"comment": "curly braces",
					"name": "punctuation.brackets.curly.bst",
					"match": "[{}]"
				},
				{
					"comment": "parentheses, round brackets",
					"name": "punctuation.brackets.round.bst",
					"match": "[()]"
				},
				{
					"comment": "semicolon",
					"name": "punctuation.semi.bst",
					"match": ";"
				},
				{
					"comment": "square brackets",
					"name": "punctuation.brackets.square.bst",
					"match": "[\\[\\]]"
				},
				{
					"comment": "angle brackets",
					"name": "punctuation.brackets.angle.bst",
					"match": "(?<!=)[<>]"
				},
                {
                    "comment": "export symbol '@'",
                    "name": "punctuation.export.bst",
                    "match": "@"
                }
			]
		},
        "variables": {
			"patterns": [
				{
					"comment": "variables",
					"name": "variable.language.bst",
					"match": "\\b(?<!(?<!\\.)\\.)(?:r#)?[a-z0-9_]+\\b"
				}
			]
		},
        "scene-tags" : {
            "patterns": [
                {
                    "name": "variable.language.tag.bst",
                    "match": "\\b(?<!(?<!\\.)\\.)(?:r#)?[a-z0-9_]+\\b"
                }
            ]
        },
        "lib-functions" : {
            "patterns": [
                {
                    "comment": "Compiler directives",
                    "name": "support.function.bst",
                    "match": "\\b(?:#print|#import|#assert|#panic|#export)\\b"
                }
            ]
        },
        "tuples" : {
            "patterns": [
                {
                    "name": "entity.name.type.tuple.bst",
                    "begin": "\\(",
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#types"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#numbers"
                        },
                        {
                            "include": "#variables"
                        },
                        {
                            "include": "#punctuation"
                        },
                        {
                            "include": "#collections"
                        },
                        {
                            "include": "#lib-functions"
                        },
                        {
                            "include": "#operators"
                        },
                        {
                            "include": "#assignment"
                        },
                        {
                            "include": "#scenes"
                        }
                    ]
                }
            ]
        },
        "code-blocks" : {
            "patterns": [
                {
                    "name": "source.bst",
                    "begin": "Code.*?(?=:)",
                    "end": "(?=\\])",
                    "patterns": [
                        {
                            "include": "#comments"
                        },
                        {
                            "include": "#types"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#scenes"
                        },
                        {
                            "include": "#lib-functions"
                        },
                        {
                            "include": "#assignment"
                        },
                        {
                            "include": "#operators"
                        },
                        {
                            "include": "#numbers"
                        },
                        {
                            "include": "#control-statement"
                        },
                        {
                            "include": "#punctuation"
                        },
                        {
                            "include": "#collections"
                        },
                        {
                            "include": "#variables"
                        }
                    ]
                }
            ]
        }
    }
}