{
  "version": "0.2.2",
  "name": "Moth Template Comment Directives",
  "scopeName": "source.moth.comment-directives",
  "injectionSelector": "L:(source.moth, source.mtf) - string - comment",
  "patterns": [
    {
      "include": "#template-todo-comment"
    },
    {
      "include": "#template-note-comment"
    },
    {
      "include": "#template-doc-comment"
    }
  ],
  "repository": {
    "template-comment-head": {
      "patterns": [
        {
          "include": "source.moth#template-head"
        }
      ]
    },
    "template-comment-body": {
      "patterns": [
        {
          "name": "meta.template.body.moth",
          "begin": ":",
          "beginCaptures": {
            "0": {
              "name": "punctuation.separator.template.head-body.moth keyword.control.scope.delimiter.moth"
            }
          },
          "end": "(?=(?<!\\\\)\\])",
          "contentName": "comment.line.double-dash.moth comment.block.template.comment.moth",
          "patterns": [
            {
              "name": "comment.line.double-dash.moth comment.block.template.comment.moth",
              "match": "[^\\[\\]]+"
            },
            {
              "name": "comment.line.double-dash.moth comment.block.template.comment.moth",
              "match": "[\\[\\]]"
            }
          ]
        }
      ]
    },
    "template-doc-body": {
      "patterns": [
        {
          "name": "meta.template.body.moth",
          "begin": ":",
          "beginCaptures": {
            "0": {
              "name": "punctuation.separator.template.head-body.moth keyword.control.scope.delimiter.moth"
            }
          },
          "end": "(?=(?<!\\\\)\\])",
          "patterns": [
            {
              "include": "source.moth#escapes"
            },
            {
              "include": "source.moth#template-slot-marker"
            },
            {
              "include": "source.moth#template-code-js"
            },
            {
              "include": "source.moth#template-code-ts"
            },
            {
              "include": "source.moth#template-code-py"
            },
            {
              "include": "source.moth#template-code-rs"
            },
            {
              "include": "source.moth#template-code-shell"
            },
            {
              "include": "source.moth#template-code-moth"
            },
            {
              "include": "source.moth#template-code-generic"
            },
            {
              "include": "source.moth#template-css"
            },
            {
              "include": "source.moth#template-html"
            },
            {
              "include": "source.moth#template-markdown"
            },
            {
              "include": "source.moth#template-generic"
            },
            {
              "include": "source.moth#embedded-markdown"
            }
          ]
        }
      ]
    },
    "template-todo-comment": {
      "patterns": [
        {
          "name": "meta.template.moth meta.template.comment.todo.moth",
          "begin": "(?<!\\\\)\\[(?=[^\\]\\n]*\\$todo\\b)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.template.begin.moth"
            }
          },
          "end": "(?<!\\\\)\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.template.end.moth"
            }
          },
          "patterns": [
            {
              "include": "#template-comment-head"
            },
            {
              "include": "#template-comment-body"
            }
          ]
        }
      ]
    },
    "template-note-comment": {
      "patterns": [
        {
          "name": "meta.template.moth meta.template.comment.note.moth",
          "begin": "(?<!\\\\)\\[(?=[^\\]\\n]*\\$note\\b)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.template.begin.moth"
            }
          },
          "end": "(?<!\\\\)\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.template.end.moth"
            }
          },
          "patterns": [
            {
              "include": "#template-comment-head"
            },
            {
              "include": "#template-comment-body"
            }
          ]
        }
      ]
    },
    "template-doc-comment": {
      "patterns": [
        {
          "name": "meta.template.moth meta.template.doc.moth meta.template.markdown.moth",
          "begin": "(?<!\\\\)\\[(?=[^\\]\\n]*\\$doc\\b)",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.template.begin.moth"
            }
          },
          "end": "(?<!\\\\)\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.template.end.moth"
            }
          },
          "patterns": [
            {
              "include": "#template-comment-head"
            },
            {
              "include": "#template-doc-body"
            }
          ]
        }
      ]
    }
  }
}
