{
  "name": "moth-highligher",
  "displayName": "Moth",
  "description": "Syntax highlighting for Moth",
  "version": "0.2.6",
  "files": [
    "package.json",
    "syntaxes/bst.tmLanguage.json",
    "syntaxes/bst-import-groups.tmLanguage.json",
    "syntaxes/bst-comment-directives.tmLanguage.json",
    "syntaxes/bd.tmLanguage.json",
    "language-configuration.json",
    "icons/moth.png",
    "icons/moth.png",
    "icons/moth-template.png",
    "LICENSE"
  ],
  "publisher": "Nye",
  "license": "Apache-2.0",
  "icon": "icons/moth.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:grammar": "node --test tests/*.test.js"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "moth",
        "aliases": [
          "moth"
        ],
        "extensions": [
          ".moth"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/moth.png",
          "dark": "./icons/moth.png"
        }
      },
      {
        "id": "mothtemplatefile",
        "aliases": [
          "mothtemplate",
          "mtf"
        ],
        "extensions": [
          ".mtf"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/moth-template.png",
          "dark": "./icons/moth-template.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "moth",
        "scopeName": "source.moth",
        "path": "./syntaxes/moth.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.markdown.moth": "markdown",
          "meta.embedded.block.css.moth": "css",
          "meta.embedded.block.html.moth": "html",
          "meta.embedded.block.code.js.moth": "javascript",
          "meta.embedded.block.code.ts.moth": "typescript",
          "meta.embedded.block.code.py.moth": "python",
          "meta.embedded.block.code.mothlang.moth": "bst",
          "meta.embedded.block.code.generic.moth": "plaintext",
          "meta.embedded.block.code.rs.moth": "rust",
          "meta.embedded.block.code.shell.moth": "shellscript"
        }
      },
      {
        "scopeName": "source.moth.import-groups",
        "path": "./syntaxes/moth-import-groups.tmLanguage.json",
        "injectTo": [
          "source.moth"
        ]
      },
      {
        "scopeName": "source.moth.comment-directives",
        "path": "./syntaxes/moth-comment-directives.tmLanguage.json",
        "injectTo": [
          "source.moth",
          "source.mtf"
        ]
      },
      {
        "language": "mtf",
        "scopeName": "source.mtf",
        "path": "./syntaxes/mtf.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.markdown.moth": "markdown",
          "meta.embedded.block.css.moth": "css",
          "meta.embedded.block.html.moth": "html",
          "meta.embedded.block.code.js.moth": "javascript",
          "meta.embedded.block.code.ts.moth": "typescript",
          "meta.embedded.block.code.py.moth": "python",
          "meta.embedded.block.code.mothlang.moth": "bst",
          "meta.embedded.block.code.generic.moth": "plaintext",
          "meta.embedded.block.code.rs.moth": "rust",
          "meta.embedded.block.code.shell.moth": "shellscript"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/H3licopter/moth-plugin"
  }
}
